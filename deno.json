{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --env=.env --watch src/app/server.ts",
    "db:generate": "deno run -A --env=.env npm:prisma generate",
    "db:migrate": "deno run -A --env=.env npm:prisma migrate dev",
    "db:push": "deno run -A --env=.env npm:prisma db push",
    "db:studio": "deno run -A --env=.env npm:prisma studio"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.7",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.5.0",
    "@prisma/client": "npm:@prisma/client@^7.5.0",
    "@std/assert": "jsr:@std/assert@1",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.99.1",
    "dotenv": "npm:dotenv@^16.6.1",
    "prisma": "npm:prisma@^7.5.0",
    "zod": "npm:zod@^4.3.6"
  },
  "allowScripts": ["npm:@prisma/engines@7.5.0", "npm:prisma@7.5.0"]
}
